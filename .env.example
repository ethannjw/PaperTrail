# ReceiptScanner Environment Configuration
# Copy this to understand what credentials are needed.
# Actual secrets are stored in iOS Keychain (entered via Settings screen)
# and Config.plist (copied from Config.plist.template).

# AI Provider API Keys (entered in-app via Settings > API Keys)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...
CLAUDE_API_KEY=sk-ant-...

# Google OAuth (configured in Config.plist)
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_REDIRECT_URI=com.yourcompany.receiptscanner:/oauth2callback

# Google Resources (configured in Config.plist)
GOOGLE_DRIVE_FOLDER_ID=1ABCDefgHIJklmNOPqrs
GOOGLE_SPREADSHEET_ID=1ABCDefgHIJklmNOPqrs-tuvwxyz

# Default AI Provider: openai | gemini | claude | mock
AI_PROVIDER=mock
PROCESSING_MODE=vision
